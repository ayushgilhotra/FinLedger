# Server Port
PORT=3000

# MongoDB URI - Get this from MongoDB Atlas
# Format: mongodb+srv://<username>:<password>@cluster0.abcde.mongodb.net/finledger?retryWrites=true&w=majority
MONGO_URI=your_mongodb_atlas_connection_string

# JWT Secret Key - Use a long, random string
JWT_SECRET=your_super_secret_jwt_key_here

# Optional: Environment
NODE_ENV=production
